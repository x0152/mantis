FROM node:22-alpine AS builder
WORKDIR /app
RUN corepack enable
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY . .
ARG VITE_LLM_BASE_URL
ARG VITE_LLM_API_KEY
ARG VITE_LLM_MODEL
ARG VITE_TG_BOT_TOKEN
ARG VITE_TG_USER_IDS
ENV VITE_LLM_BASE_URL=$VITE_LLM_BASE_URL \
    VITE_LLM_API_KEY=$VITE_LLM_API_KEY \
    VITE_LLM_MODEL=$VITE_LLM_MODEL \
    VITE_TG_BOT_TOKEN=$VITE_TG_BOT_TOKEN \
    VITE_TG_USER_IDS=$VITE_TG_USER_IDS
RUN pnpm build

FROM nginx:1.27-alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
