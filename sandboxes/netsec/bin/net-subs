#!/usr/bin/env bash
set -euo pipefail

if [ $# -lt 1 ]; then
    echo "Usage: net-subs <domain>" >&2
    exit 1
fi

DOMAIN="$1"
WL=/usr/share/wordlists/mantis/subdomains-top.txt

if [ ! -f "$WL" ]; then
    echo "wordlist not found: $WL" >&2
    exit 1
fi

echo "Brute-forcing subdomains for $DOMAIN (wordlist: $WL)..."

probe() {
    local sub="$1" domain="$2"
    [ -z "$sub" ] && return 0
    local fqdn="$sub.$domain"
    local ip
    ip=$(timeout --foreground 4 dig +short +time=2 +tries=2 "$fqdn" A 2>/dev/null | grep -E '^[0-9.]+$' | head -1 || true)
    if [ -n "$ip" ]; then
        printf "  %-40s %s\n" "$fqdn" "$ip"
    fi
}

export -f probe

timeout --foreground --kill-after 10 120 \
    xargs -a "$WL" -n 1 -P 20 -I {} bash -c 'probe "$@"' _ {} "$DOMAIN"
