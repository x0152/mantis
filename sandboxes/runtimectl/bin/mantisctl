#!/usr/bin/env bash
set -euo pipefail

MANTIS_URL="${MANTIS_URL:-http://app:8080}"
MANTIS_RUNTIME_TOKEN="${MANTIS_RUNTIME_TOKEN:-}"

usage() {
  cat >&2 <<'EOF'
mantisctl - CLI for the Mantis runtime sandbox lifecycle

  mantisctl sandbox create <name> [-f Dockerfile|-] [--description TEXT] [--profile ID ...]
      Upsert the connection (stores Dockerfile in DB), build the image, run the
      container and return when it's ready. Streams build logs.

  mantisctl sandbox ls                list sandboxes with state
  mantisctl sandbox rebuild <name>    rebuild from stored Dockerfile + restart
  mantisctl sandbox start   <name>    start stopped container
  mantisctl sandbox stop    <name>    stop container (connection kept)
  mantisctl sandbox rm      <name>    stop + remove container + delete connection

Environment:
  MANTIS_URL             default http://app:8080
  MANTIS_RUNTIME_TOKEN   required if the server enforces a token
EOF
}

curl_auth() {
  local args=(--silent --show-error --fail-with-body --no-buffer)
  if [ -n "$MANTIS_RUNTIME_TOKEN" ]; then
    args+=(-H "X-Runtime-Token: ${MANTIS_RUNTIME_TOKEN}")
  fi
  curl "${args[@]}" "$@"
}

cmd_sandbox_list() {
  curl_auth "${MANTIS_URL}/api/runtime/sandboxes" \
    | jq -r '.sandboxes[] | [.connection.name, .state, (.connection.profileIds[0] // "-"), .container.image] | @tsv' \
    | awk 'BEGIN{printf "%-20s %-12s %-14s %s\n","NAME","STATE","PROFILE","IMAGE"} {printf "%-20s %-12s %-14s %s\n",$1,$2,$3,$4}'
}

cmd_sandbox_create() {
  local name="${1:-}"; shift || true
  [ -z "$name" ] && { echo "sandbox create: <name> required" >&2; exit 2; }
  local file="-"
  local description=""
  local profiles_json="[]"
  while [ "$#" -gt 0 ]; do
    case "$1" in
      -f|--file) file="${2:-}"; shift 2 ;;
      --description) description="${2:-}"; shift 2 ;;
      --profile)
        profiles_json=$(jq -c --arg p "${2:-}" '. + [$p]' <<<"$profiles_json")
        shift 2 ;;
      *) echo "sandbox create: unknown arg $1" >&2; exit 2 ;;
    esac
  done
  local dockerfile
  if [ "$file" = "-" ]; then
    dockerfile=$(cat)
  else
    dockerfile=$(cat "$file")
  fi
  [ -z "$dockerfile" ] && { echo "sandbox create: dockerfile is empty" >&2; exit 2; }
  local payload
  payload=$(jq -n \
    --arg name "$name" \
    --arg description "$description" \
    --arg dockerfile "$dockerfile" \
    --argjson profiles "$profiles_json" \
    '{name:$name, description:$description, dockerfile:$dockerfile, profileIds:$profiles}')
  curl_auth -X POST -H "Content-Type: application/json" \
    --data-binary "$payload" \
    "${MANTIS_URL}/api/runtime/sandboxes"
}

cmd_sandbox() {
  local sub="${1:-}"; shift || true
  case "$sub" in
    create)    cmd_sandbox_create "$@" ;;
    ls|list)   cmd_sandbox_list ;;
    rebuild)   curl_auth -X POST "${MANTIS_URL}/api/runtime/sandboxes/${1:-}/rebuild" ;;
    start)     curl_auth -X POST "${MANTIS_URL}/api/runtime/sandboxes/${1:-}/start" ;;
    stop)      curl_auth -X POST "${MANTIS_URL}/api/runtime/sandboxes/${1:-}/stop" ;;
    rm)        curl_auth -X DELETE "${MANTIS_URL}/api/runtime/sandboxes/${1:-}" ;;
    "")        echo "sandbox: subcommand required" >&2; usage; exit 2 ;;
    *)         echo "sandbox: unknown subcommand $sub" >&2; exit 2 ;;
  esac
}

main() {
  [ "$#" -eq 0 ] && { usage; exit 2; }
  local cmd="$1"; shift
  case "$cmd" in
    sandbox)        cmd_sandbox "$@" ;;
    -h|--help|help) usage ;;
    *) echo "unknown command: $cmd" >&2; usage; exit 2 ;;
  esac
}

main "$@"
